# Используем официальный, стабильный и легкий образ Python
FROM python:3.11-slim

# Устанавливаем рабочую директорию внутри контейнера
WORKDIR /app

# Копируем файл зависимостей и устанавливаем их (без кэша, чтобы образ был легким)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Копируем весь остальной код проекта в контейнер
COPY . .

# Команда, которая автоматически запустится при старте контейнера на сервере
CMD ["python", "bot.py"]